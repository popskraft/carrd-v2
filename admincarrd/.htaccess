Options -Indexes

RewriteEngine On

RewriteRule ^(?:app|var|docs)(/|$) - [F,L]
RewriteRule ^(?:login|logout|setup|process|reset|config-ui|change-password)\.php$ index.php [L,QSA]

<FilesMatch "^(?:router\.php|AGENTS\.md|\.htaccess|\.user\.ini|config\.php|setup-token\.txt)$">
  Require all denied
</FilesMatch>

<IfModule mod_php7.c>
  php_value max_execution_time 120
  php_value max_input_time 120
  php_value memory_limit 256M
  php_value upload_max_filesize 100M
  php_value post_max_size 110M
</IfModule>

<IfModule mod_php8.c>
  php_value max_execution_time 120
  php_value max_input_time 120
  php_value memory_limit 256M
  php_value upload_max_filesize 100M
  php_value post_max_size 110M
</IfModule>
