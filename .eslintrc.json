{
  "env": {
    "browser": true,
    "es2020": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "overrides": [
    {
      "files": [
        "tests-js/**/*.js"
      ],
      "env": {
        "node": true,
        "es2020": true
      }
    }
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error"
  }
}
