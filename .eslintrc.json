{
  "env": {
    "browser": true,
    "es2020": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "overrides": [
    {
      "files": [
        "src/**/*.js"
      ],
      "rules": {
        "complexity": ["error", 10]
      }
    },
    {
      "files": [
        "tests-js/**/*.js"
      ],
      "env": {
        "node": true,
        "es2020": true
      }
    },
    {
      "files": [
        "cardbuilder/scripts/**/*.mjs",
        "tests-js/**/*.mjs"
      ],
      "env": {
        "node": true,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "rules": {
        "no-empty": ["error", { "allowEmptyCatch": true }]
      }
    }
  ],
  "rules": {
    "no-unused-vars": "error",
    "no-undef": "error"
  }
}
